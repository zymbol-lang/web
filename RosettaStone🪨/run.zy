// RosettaStone🪨 — run.zy
// Validates all FizzBuzz variants (greeting + FizzBuzz 1..15)
// Usage: zymbol run RosettaStone🪨/run.zy   (from project root)

// ANSI colors via tput
GREEN = <\ tput setaf 2 \>
RED   = <\ tput setaf 1 \>
CYAN  = <\ tput setaf 6 \>
BOLD  = <\ tput bold \>
DIM   = <\ tput dim \>
RESET = <\ tput sgr0 \>

