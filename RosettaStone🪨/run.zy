]

pass = 0
fail = 0
total = langs$#

>> ¶
>> CYAN BOLD "=== Rosetta Stone 🪨 — FizzBuzz in " total " Languages ===" RESET ¶
>> ¶

@ lang:langs {
    label    = lang[0]
    _file    = lang[1]
    greeting = lang[2]
    fizzW    = lang[3]
    buzzW    = lang[4]

    out = <\ zymbol run {_file} \>

    part1    = "1\n2\n", fizzW, "\n4\n", buzzW, "\n", fizzW, "\n7\n8\n"
    part2    = fizzW, "\n", buzzW, "\n11\n", fizzW, "\n13\n14\n", fizzW, buzzW, "\n"
    seq      = part1, part2
    expected = greeting, "\n", seq

    ? out == expected {
        >> GREEN "  ✓ " RESET BOLD label RESET "  " DIM greeting RESET ¶
        pass = pass + 1
    }
    _ {
        >> RED "  ✗ " RESET BOLD label RESET ¶
        fail = fail + 1
    }
}

>> ¶
>> BOLD "  Results: " GREEN pass RESET " passed, " RED fail RESET " failed / " total " total" RESET ¶
>> ¶
