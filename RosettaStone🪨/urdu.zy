// FizzBuzz — اردو
// Identifiers in اردو. Operators are always symbolic.
// Numeral mode: native digits (۰–۹).

>> "السلام علیکم، اردو دنیا!" ¶

#۰۹#

درجہ_بندی(عدد) {
    ? عدد % ۱۵ == ۰ { <~ "بلبلہگنگناہٹ" }
    _? عدد % ۳  == ۰ { <~ "بلبلہ" }
    _? عدد % ۵  == ۰ { <~ "گنگناہٹ" }
    _ { <~ عدد }
}

@ ن:۱..۱۵ {
    >> درجہ_بندی(ن) ¶
}
