// FizzBuzz — नेपाली
// Identifiers in नेपाली. Operators are always symbolic.
// Numeral mode: native digits (०–९).

>> "नमस्ते, नेपाली संसार!" ¶

#०९#

वर्गीकरण(संख्या) {
    ? संख्या % १५ == ० { <~ "बुलबुलेभनभन" }
    _? संख्या % ३  == ० { <~ "बुलबुले" }
    _? संख्या % ५  == ० { <~ "भनभन" }
    _ { <~ संख्या }
}

@ न:१..१५ {
    >> वर्गीकरण(न) ¶
}
