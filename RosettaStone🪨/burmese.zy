// FizzBuzz — မြန်မာဘာသာ
// မြန်မာဘာသာဖြင့် identifier များ။ Operator များ အမြဲ သင်္ကေတဖြစ်သည်။

>> "မင်္ဂလာပါ, ကမ္ဘာ!" ¶

သတ်မှတ်(နံပါတ်) {
    ? နံပါတ် % 15 == 0 { <~ "ဗူးဆူညံ" }
    _? နံပါတ် % 3  == 0 { <~ "ဗူး" }
    _? နံပါတ် % 5  == 0 { <~ "ဆူညံ" }
    _ { <~ နံပါတ် }
}

@ ည:1..15 {
    >> သတ်မှတ်(ည) ¶
}
