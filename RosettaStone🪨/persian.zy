// FizzBuzz — فارسی
// Identifiers in فارسی. Operators are always symbolic.
// Numeral mode: native digits (۰–۹).

>> "سلام، دنیای فارسی‌زبان!" ¶

#۰۹#

دسته_بندی(عدد) {
    ? عدد % ۱۵ == ۰ { <~ "حبابوزوز" }
    _? عدد % ۳  == ۰ { <~ "حباب" }
    _? عدد % ۵  == ۰ { <~ "وزوز" }
    _ { <~ عدد }
}

@ ن:۱..۱۵ {
    >> دسته_بندی(ن) ¶
}
