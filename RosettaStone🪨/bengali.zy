// FizzBuzz — বাংলা
// Identifiers in বাংলা. Operators are always symbolic.
// Numeral mode: native digits (০–৯).

>> "নমস্কার, বাংলাভাষী বিশ্ব!" ¶

#০৯#

শ্রেণীবিভাগ(সংখ্যা) {
    ? সংখ্যা % ১৫ == ০ { <~ "বুদবুদভনভন" }
    _? সংখ্যা % ৩  == ০ { <~ "বুদবুদ" }
    _? সংখ্যা % ৫  == ০ { <~ "ভনভন" }
    _ { <~ সংখ্যা }
}

@ ন:১..১৫ {
    >> শ্রেণীবিভাগ(ন) ¶
}
