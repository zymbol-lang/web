// FizzBuzz — हिन्दी
// Identifiers in हिन्दी. Operators are always symbolic.
// Numeral mode: native digits (०–९).

>> "नमस्ते, हिन्दी भाषी दुनिया!" ¶

#०९#

वर्गीकरण(संख्या) {
    ? संख्या % १५ == ० { <~ "बुलबुलाभनभन" }
    _? संख्या % ३  == ० { <~ "बुलबुला" }
    _? संख्या % ५  == ० { <~ "भनभन" }
    _ { <~ संख्या }
}

@ न:१..१५ {
    >> वर्गीकरण(न) ¶
}
