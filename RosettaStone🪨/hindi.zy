// FizzBuzz — हिन्दी
// पहचानकर्ता हिन्दी में। ऑपरेटर हमेशा प्रतीकात्मक।

>> "नमस्ते, हिन्दी भाषी दुनिया!" ¶

वर्गीकरण(संख्या) {
    ? संख्या % 15 == 0 { <~ "बुलबुलाभनभन" }
    _? संख्या % 3  == 0 { <~ "बुलबुला" }
    _? संख्या % 5  == 0 { <~ "भनभन" }
    _ { <~ संख्या }
}

@ न:1..15 {
    >> वर्गीकरण(न) ¶
}
