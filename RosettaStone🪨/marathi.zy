// FizzBuzz — मराठी
// Identifiers in मराठी. Operators are always symbolic.
// Numeral mode: native digits (०–९).

>> "नमस्कार, मराठी जग!" ¶

#०९#

वर्गीकरण(संख्या) {
    ? संख्या % १५ == ० { <~ "बुडबुडेभनभन" }
    _? संख्या % ३  == ० { <~ "बुडबुडे" }
    _? संख्या % ५  == ० { <~ "भनभन" }
    _ { <~ संख्या }
}

@ न:१..१५ {
    >> वर्गीकरण(न) ¶
}
