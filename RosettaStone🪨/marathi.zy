// FizzBuzz — मराठी
// ओळखकर्ते मराठीत। ऑपरेटर नेहमी सांकेतिक।

>> "नमस्कार, मराठी बोलणाऱ्या जगा!" ¶

वर्गीकरण(संख्या) {
    ? संख्या % 15 == 0 { <~ "बुडबुडाभुणभुण" }
    _? संख्या % 3  == 0 { <~ "बुडबुडा" }
    _? संख्या % 5  == 0 { <~ "भुणभुण" }
    _ { <~ संख्या }
}

@ न:1..15 {
    >> वर्गीकरण(न) ¶
}
